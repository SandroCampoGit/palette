@{ ViewData["Title"] = "Find local artists"; }

<section class="hero">
    <span class="eyebrow">● Free promo for artists</span>
    <h1>Your talent.<br /><span class="grad">On the map.</span></h1>
    <p class="lede">
        A free, shareable artist page — plus a live feed of local briefs and collabs.
        Musicians, photographers, designers, dancers: get found by the people
        looking for exactly you.
    </p>
    <div class="cta-row">
        <a class="btn btn-primary" asp-controller="Account" asp-action="Register">Claim your free profile</a>
        <a class="btn" asp-controller="Discover" asp-action="Index">Browse artists</a>
        <a class="btn btn-ghost" asp-controller="Briefs" asp-action="Index">See open briefs →</a>
    </div>
</section>

<section class="section">
    <div class="row-head"><h2>How it works</h2></div>
    <div class="grid-3">
        <div class="feature">
            <div class="ic">◎</div>
            <h3>A page worth sharing</h3>
            <p>Portfolio, links and endorsements at /a/your-name. Free forever — drop it in your bio instead of a link tree.</p>
        </div>
        <div class="feature">
            <div class="ic">⚲</div>
            <h3>Found by location</h3>
            <p>Appear on the map for creators searching your city. GPS if you allow it, your suburb if you don't.</p>
        </div>
        <div class="feature">
            <div class="ic">⇄</div>
            <h3>Real opportunities</h3>
            <p>Briefs from people who need your discipline, near you, with a budget. Respond in one tap — get hired, get endorsed.</p>
        </div>
    </div>
</section>

<section class="section" style="text-align:center; padding-top:12px">
    <div class="panel" style="max-width:640px; margin:0 auto; background:linear-gradient(135deg, rgba(140,103,245,.15), rgba(30,215,96,.1)), var(--surface)">
        <h3 style="margin:0 0 6px; font-size:22px; letter-spacing:-.02em; font-weight:800">Two ways in</h3>
        <p style="color:var(--muted); margin:0 0 20px">Join as a creator to be found, or as a finder to discover and book local talent.</p>
        <div class="cta-row" style="justify-content:center">
            <a class="btn btn-primary" asp-controller="Account" asp-action="Register">Join free</a>
            <a class="btn" asp-controller="Discover" asp-action="Index">See who's around</a>
        </div>
    </div>
</section>
