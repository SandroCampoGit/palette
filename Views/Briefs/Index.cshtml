@model List<Brief>
@{ ViewData["Title"] = "Briefs"; }

<div class="page-head">
    <div>
        <h1>Open briefs</h1>
        <p class="sub">Real opportunities from people looking for local artists.</p>
    </div>
    <a class="btn btn-primary" asp-controller="Briefs" asp-action="Create">Post a brief</a>
</div>

<form method="get" class="filters" id="briefFilter">
    <select name="discipline" onchange="document.getElementById('briefFilter').submit()">
        <option value="">All disciplines</option>
        @foreach (var d in Html.GetEnumSelectList<Discipline>())
        {
            var sel = ViewBag.Discipline?.ToString() == ((Discipline)int.Parse(d.Value!)).ToString();
            <option value="@d.Value" selected="@sel">@d.Text</option>
        }
    </select>
    <input type="text" name="city" value="@ViewBag.City" placeholder="City" />
    <button type="submit" class="btn btn-sm">Filter</button>
</form>

@if (Model.Any())
{
    foreach (var b in Model)
    {
        <a class="brief-card" asp-controller="Briefs" asp-action="Details" asp-route-id="@b.Id">
            <div class="title">@b.Title</div>
            <div class="desc">@b.Description</div>
            <div class="meta">
                <span class="chip violet">@b.Discipline</span>
                @if (!string.IsNullOrEmpty(b.City)) { <span class="chip grey">@b.City</span> }
                @if (!string.IsNullOrEmpty(b.Budget)) { <span class="chip green">@b.Budget</span> }
                @if (b.NeededBy != null) { <span>· by @b.NeededBy.Value.ToString("d MMM")</span> }
                <span>· @b.Responses.Count response@(b.Responses.Count == 1 ? "" : "s")</span>
                <span>· @b.CreatedAtUtc.ToString("d MMM")</span>
            </div>
        </a>
    }
}
else
{
    <div class="empty">No open briefs yet. <a asp-controller="Briefs" asp-action="Create">Post the first one.</a></div>
}
