@model RegisterViewModel
@{ ViewData["Title"] = "Join free"; }
<div class="auth-wrap">
    <h1>Create your account</h1>
    <p class="sub">Free profile, no card. Takes 30 seconds.</p>
    <div class="panel">
        <form asp-controller="Account" asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors form-row"></div>

            <div class="form-row">
                <label>I'm joining as</label>
                <div class="mode-toggle">
                    <input type="radio" asp-for="PrimaryMode" value="Artist" id="mArtist" />
                    <label for="mArtist">🎨 Creator<br /><span style="font-size:12px;color:var(--faint)">be found</span></label>
                    <input type="radio" asp-for="PrimaryMode" value="Finder" id="mFinder" />
                    <label for="mFinder">🔎 Finder<br /><span style="font-size:12px;color:var(--faint)">discover talent</span></label>
                </div>
            </div>

            <div class="form-row">
                <label asp-for="DisplayName"></label>
                <input asp-for="DisplayName" placeholder="e.g. Sandro C" />
                <span asp-validation-for="DisplayName" class="text-danger"></span>
            </div>
            <div class="form-row">
                <label asp-for="Email"></label>
                <input asp-for="Email" type="email" placeholder="you@email.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-row two">
                <div>
                    <label asp-for="City"></label>
                    <input asp-for="City" placeholder="Johannesburg" />
                </div>
                <div>
                    <label asp-for="Suburb"></label>
                    <input asp-for="Suburb" placeholder="Parkhurst" />
                </div>
            </div>
            <div class="form-row two">
                <div>
                    <label asp-for="Password"></label>
                    <input asp-for="Password" type="password" placeholder="8+ characters" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="ConfirmPassword"></label>
                    <input asp-for="ConfirmPassword" type="password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
            </div>
            <button type="submit" class="btn btn-primary btn-block">Create account</button>
        </form>
    </div>
    <p class="sub" style="text-align:center;margin-top:16px">
        Already have an account? <a asp-controller="Account" asp-action="Login">Sign in</a>
    </p>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
